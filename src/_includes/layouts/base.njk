<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {% endif %}{{ site.shortTitle }}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}" />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="3340f8f5-19a5-4e76-9fe6-4bbf6c4ae33f"></script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    {% include "partials/header.njk" %}
    <main id="main" class="container">
      {{ content | safe }}
    </main>
    {% include "partials/footer.njk" %}
    <script src="{{ '/assets/js/site.js' | url }}" defer></script>
    {% if extraScript %}<script src="{{ extraScript | url }}" defer></script>{% endif %}
  </body>
</html>
