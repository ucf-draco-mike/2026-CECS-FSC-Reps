<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <strong>{{ site.title }}</strong>
      <p>{{ site.college }}<br />{{ site.university }}</p>
    </div>
    <div>
      <p class="footer-links">
        <a href="{{ '/committees/' | url }}">Committees</a>
        <a href="{{ '/how-it-works/' | url }}">How it works</a>
        <a href="{{ '/stats/' | url }}">Stats</a>
        <a href="{{ '/volunteers/' | url }}">Volunteer summary</a>
        <a href="{{ '/signup/' | url }}">Volunteer</a>
        <a href="{{ '/updates/' | url }}">Updates</a>
        <a href="{{ site.committeesReferenceUrl }}" rel="noopener" target="_blank">UCF Faculty Senate ↗</a>
      </p>
      <p class="footer-contact">
        Questions? <a href="mailto:{{ site.contactEmail }}">{{ site.contactName }}</a>
        {% if site.contactTitle %}<br /><span class="footer-meta">{{ site.contactTitle }}{% if site.contactDepartment %} · {{ site.contactDepartment }}{% endif %}</span>{% endif %}
      </p>
      {% if signups.generatedAt %}
        <p class="footer-meta">Volunteer data last updated {{ signups.generatedAt | readableDate }}.</p>
      {% endif %}
      <p class="footer-meta"><a href="{{ '/about/#ai-disclosure' | url }}">AI use disclosure</a></p>
    </div>
  </div>
</footer>
